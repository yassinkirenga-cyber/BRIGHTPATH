# Copy this file to .env and fill in your values
# Get these from https://supabase.com (free account)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Get this from https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: use these if you need to manage Anthropic API keys via CLI
ANTHROPIC_API_KEY_ID=your_anthropic_api_key_id
ANTHROPIC_OAUTH_TOKEN=your_anthropic_oauth_token

# Get this from Google Gemini / Generative Language
GEMINI_API_KEY=your_gemini_api_key
